          <mxGeometry height="100" width="100" x="680" y="160" as="geometry" />
        </mxCell>
        <mxCell id="queue_label" parent="1" style="text;html=1;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#0078D4;" value="Storage Queue&#xa;sp-indexer-q&#xa;+ poison queue" vertex="1">
