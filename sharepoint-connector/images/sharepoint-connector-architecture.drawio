        <mxCell id="dispatcher" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#FFFFFF;strokeColor=#005A9E;strokeWidth=3;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" value="Azure Function — Dispatcher&#xa;(Timer Trigger)&#xa;&#xa;1. Resolve processing mode&#xa;   (full / since-date / watermark)&#xa;2. List changed files via Graph&#xa;3. Enqueue one message per file&#xa;4. Advance watermark" vertex="1">
