<mxfile host="65bd71144e">
    <diagram id="sp-connector-arch-v3" name="SharePoint Connector Architecture v3 (Updated)">
        <mxGraphModel dx="258" dy="284" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="SharePoint → Azure AI Search — Updated Architecture&#xa;(Azure OpenAI Embeddings · Visio &amp; Video Support · Azure Speech Transcription · Metadata Column Filter)" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="280" y="10" width="1340" height="52" as="geometry"/>
                </mxCell>
                <mxCell id="lane1" value="Ingestion Pipeline  (timer dispatcher → metadata filter → queue → parallel workers)" style="text;html=1;fontSize=13;fontStyle=3;align=left;verticalAlign=middle;fillColor=#E6F0FF;strokeColor=#0078D4;rounded=1;arcSize=20;fontColor=#0078D4;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="72" width="1790" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="lane2" value="Retrieval Flow  (Copilot Studio → azureOpenAI vectorizer embeds question → hybrid search)" style="text;html=1;fontSize=13;fontStyle=3;align=left;verticalAlign=middle;fillColor=#F3E6F3;strokeColor=#742774;rounded=1;arcSize=20;fontColor=#742774;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="882" width="1790" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="graphapi" value="Microsoft Graph API&#xa;&#xa;Sites.Read.All · Files.Read.All&#xa;$expand=listItem($expand=fields)&#xa;when METADATA_FILTERS is set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;" parent="1" vertex="1">
                    <mxGeometry x="68" y="140" width="190" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="sharepoint" value="SharePoint Online&#xa;&#xa;Document Libraries&#xa;PDF · Office (DOCX/XLSX/PPTX)&#xa;Images (PNG/JPG/TIFF/…)&#xa;Visio (.vsdx / .vsd)&#xa;Video (.mp4 / .mov / .avi / …)&#xa;&#xa;+ SharePoint metadata columns" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#217346;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="68" y="340" width="190" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="dispatcher" value="Azure Function — Dispatcher&#xa;(Timer Trigger)&#xa;&#xa;1. Resolve processing mode&#xa;   (full / since-date / watermark&#xa;    / delta since-last-run)&#xa;2. List changed files via Graph&#xa;   • applies $expand=listItem&#xa;     for delta: per-item field fetch&#xa;3. Apply metadata column filter&#xa;   (METADATA_FILTERS env var)&#xa;   Skip non-matching files&#xa;4. Enqueue one message per file&#xa;5. Advance watermark" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#FFFFFF;strokeColor=#005A9E;strokeWidth=3;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="322" y="108" width="258" height="268" as="geometry"/>
                </mxCell>
                <mxCell id="queue" value="sp-indexer-q&#xa;+ poison queue" style="shape=mxgraph.azure.queue;fillColor=#0078D4;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;" parent="1" vertex="1">
                    <mxGeometry x="665" y="165" width="100" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="worker" value="Azure Function — Worker&#xa;(Queue Trigger — up to 40 instances)&#xa;&#xa;1. Stream download from SharePoint → /tmp&#xa;2. Extract text by file type:&#xa;   · PDF/DOCX/XLSX/PPTX (DocIntel or native)&#xa;   · Images — gpt-4o caption + context embed&#xa;   · Visio .vsdx — ZIP-based XML extractor&#xa;   · Visio .vsd — LibreOffice fallback&#xa;   · Video → Azure Speech Fast Transcription&#xa;     (PyAV extracts audio → 60s text blocks)&#xa;3. Block-boundary chunking&#xa;4. Embed all text via Azure OpenAI (3072d)&#xa;5. Push chunks + vectors to AI Search&#xa;6. On failure → failedFiles table,&#xa;   5× dequeue → poison queue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#FFFFFF;strokeColor=#005A9E;strokeWidth=3;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="858" y="108" width="300" height="298" as="geometry"/>
                </mxCell>
                <mxCell id="appinsights" value="App Insights&#xa;+ Log Analytics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#68217A;fontColor=#FFFFFF;strokeColor=none;fontSize=10;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;" parent="1" vertex="1">
                    <mxGeometry x="650" y="388" width="168" height="52" as="geometry"/>
                </mxCell>
                <mxCell id="openai" value="Azure OpenAI — PRIMARY&#xa;(Microsoft Foundry AIServices account)&#xa;&#xa;text-embedding-3-large (3072d)&#xa;All text chunks embedded here.&#xa;Used at ingest AND at query time&#xa;via the azureOpenAI vectorizer.&#xa;&#xa;gpt-5.1-chat — Image captioning&#xa;Images → caption + neighbour&#xa;context → embedded as text." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C45000;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="1265" y="105" width="238" height="198" as="geometry"/>
                </mxCell>
                <mxCell id="docintel" value="Document Intelligence&#xa;(prebuilt-layout) — OPTIONAL&#xa;&#xa;Reading-order paragraphs,&#xa;tables, figures with bounding&#xa;boxes for PDF/DOCX/PPTX/XLSX.&#xa;Falls back to PyMuPDF / python-docx&#xa;when DOCINTEL_ENDPOINT is empty." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#005A9E;fontColor=#FFFFFF;strokeColor=#0078D4;strokeWidth=1;fontSize=10;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1265" y="323" width="238" height="148" as="geometry"/>
                </mxCell>
                <mxCell id="content_understanding" value="Azure Speech Fast Transcription&#xa;— OPTIONAL (video files) —&#xa;&#xa;Reuses Foundry AIServices endpoint&#xa;(same account as Azure OpenAI).&#xa;PyAV extracts 16kHz mono WAV.&#xa;Single synchronous POST — no polling.&#xa;Returns 60s transcript blocks,&#xa;then embedded via text-embedding-3-large." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#006563;fontColor=#FFFFFF;strokeColor=#009180;strokeWidth=1;fontSize=10;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1265" y="491" width="238" height="152" as="geometry"/>
                </mxCell>
                <mxCell id="florence" value="Azure AI Vision — Florence 4.0&#xa;— OPTIONAL FALLBACK —&#xa;&#xa;For regions without Azure OpenAI&#xa;quota. Produces 1024d vectors.&#xa;NOT compatible with OpenAI 3072d.&#xa;Set MULTIMODAL_ENDPOINT and&#xa;leave AZURE_OPENAI_ENDPOINT empty." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5C3D85;fontColor=#FFFFFF;strokeColor=#8764B8;strokeWidth=2;fontSize=10;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1265" y="663" width="238" height="128" as="geometry"/>
                </mxCell>
                <mxCell id="aisearch" value="Azure AI Search (Basic+)&#xa;&#xa;sharepoint-index&#xa;(HNSW + Semantic Ranker)&#xa;&#xa;content_embedding (3072d)&#xa;Vectorizer: azureOpenAI&#xa;Model: text-embedding-3-large&#xa;&#xa;Fields: content, title, source,&#xa;parent_id, chunk_id, has_image,&#xa;permissions (security trimming),&#xa;content_embedding&#xa;&#xa;Hybrid: vector + keyword +&#xa;semantic ranker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0063B1;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="952" y="490" width="262" height="298" as="geometry"/>
                </mxCell>
