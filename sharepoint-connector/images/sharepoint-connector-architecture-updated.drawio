                    <mxGeometry x="258" y="530" width="458" height="262" as="geometry"/>
                </mxCell>
                <mxCell id="state_title" value="Storage-backed State (Managed Identity — no connection strings)" style="text;html=1;fontSize=12;fontStyle=3;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#D4A017;" parent="1" vertex="1">
                    <mxGeometry x="195" y="500" width="590" height="25" as="geometry"/>
