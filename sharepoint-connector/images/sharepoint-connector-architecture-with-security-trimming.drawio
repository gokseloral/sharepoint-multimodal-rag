        </mxCell>

        <mxCell id="state_watermark" value="Table: watermark&#xa;&#xa;last successful run&#xa;(per drive)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCE0FF;fontColor=#003366;strokeColor=#0078D4;fontSize=10;fontStyle=0;arcSize=15;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="478" y="497" width="170" height="80" as="geometry" />
        </mxCell>

        <mxCell id="state_failed" value="Table: failedFiles&#xa;&#xa;per-file retry count&#xa;+ terminal flag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;fontColor=#663300;strokeColor=#FF8C00;fontSize=10;fontStyle=0;arcSize=15;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="473" y="592" width="170" height="80" as="geometry" />
        </mxCell>

        <mxCell id="state_runstate" value="Table: runState&#xa;&#xa;per-run expected / completed /&#xa;failed counters" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCE0FF;fontColor=#003366;strokeColor=#0078D4;fontSize=10;fontStyle=0;arcSize=15;verticalAlign=middle;align=center;" vertex="1" parent="1">
