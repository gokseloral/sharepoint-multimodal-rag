          <mxGeometry x="1270" y="400" width="470" height="260" as="geometry" />
        </mxCell>
        <mxCell id="rbac_title" value="RBAC Role Assignments (System-Assigned Managed Identity → Services)" style="text;html=1;fontSize=11;fontStyle=3;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#217346;" vertex="1" parent="1">
          <mxGeometry x="1280" y="405" width="450" height="30" as="geometry" />
        </mxCell>
        <mxCell id="rbac_text" value="🔍  Azure AI Search&#xa;     • Search Index Data Contributor&#xa;     • Search Service Contributor&#xa;&#xa;🧠  Foundry / Azure AI Services&#xa;     • Cognitive Services User&#xa;     (multimodal embeddings + optional&#xa;      Document Intelligence)&#xa;&#xa;📦  Azure Storage (Blob / Queue / Table)&#xa;     • Blob Data Owner&#xa;     • Queue Data Contributor&#xa;     • Table Data Contributor&#xa;&#xa;🔐  Key Vault (when useClientSecret = true)&#xa;     • Key Vault Secrets User&#xa;&#xa;📧  Microsoft Graph — indexing&#xa;     • Sites.Read.All / Files.Read.All&#xa;       (or Sites.Selected for least privilege)&#xa;&#xa;📧  Microsoft Graph — /api/search&#xa;     • GroupMember.Read.All (application)" style="text;html=1;fontSize=10;fontStyle=0;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=8;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="1280" y="435" width="450" height="220" as="geometry" />
        </mxCell>

        <!-- ========== Retrieval ========== -->
        <mxCell id="copilot" value="Microsoft Copilot Studio&#xa;(Generative Orchestration)&#xa;&#xa;OnKnowledgeRequested topic&#xa;→ HTTP action&#xa;(flows user's delegated token)&#xa;&#xa;LLM sees ONLY chunks the&#xa;caller is authorised for." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#742774;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="880" width="320" height="160" as="geometry" />
        </mxCell>

        <!-- Query API (HTTP trigger of the same Function App) -->
