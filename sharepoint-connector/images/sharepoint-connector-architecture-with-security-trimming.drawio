        <mxCell id="keyvault" value="Key Vault (conditional)&#xa;&#xa;graph-client-secret&#xa;&#xa;@Microsoft.KeyVault ref&#xa;(MI has Secrets User role)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E81123;fontColor=#FFFFFF;strokeColor=none;fontSize=10;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="527" width="170" height="100" as="geometry" />
        </mxCell>

