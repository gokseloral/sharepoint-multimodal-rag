          <mxGeometry x="268" y="457" width="430" height="240" as="geometry" />
        </mxCell>
        <mxCell id="state_title" value="Storage-backed State (Managed Identity, no keys)" style="text;html=1;fontSize=12;fontStyle=3;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#D4A017;" vertex="1" parent="1">
          <mxGeometry x="211" y="427" width="560" height="25" as="geometry" />
        </mxCell>

        <mxCell id="state_blob" value="Blob: state container&#xa;&#xa;(reserved for future&#xa;large-state dumps)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCE0FF;fontColor=#003366;strokeColor=#0078D4;fontSize=10;fontStyle=0;arcSize=15;verticalAlign=middle;align=center;" vertex="1" parent="1">
