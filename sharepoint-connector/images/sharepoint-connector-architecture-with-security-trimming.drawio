<mxfile host="app.diagrams.net" modified="2026-04-22T00:00:00.000Z" agent="Claude Code" version="24.0.0" type="device">
  <diagram id="sp-connector-arch-trimmed" name="SharePoint Connector Architecture — with Per-User Security Trimming">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="SharePoint → Azure AI Search — with Per-User Security Trimming (extended)" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="15" width="900" height="40" as="geometry" />
        </mxCell>

        <!-- Swim lane: Ingestion Flow -->
        <mxCell id="lane1" value="Ingestion Pipeline  (timer dispatcher → queue → parallel workers)" style="text;html=1;fontSize=13;fontStyle=3;align=left;verticalAlign=middle;fillColor=#E6F0FF;strokeColor=#0078D4;rounded=1;arcSize=20;fontColor=#0078D4;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="1680" height="30" as="geometry" />
        </mxCell>

        <!-- Swim lane: Retrieval Flow -->
        <mxCell id="lane2" value="Retrieval Flow  (Copilot Studio queries the search index)" style="text;html=1;fontSize=13;fontStyle=3;align=left;verticalAlign=middle;fillColor=#F3E6F3;strokeColor=#742774;rounded=1;arcSize=20;fontColor=#742774;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="820" width="1680" height="30" as="geometry" />
        </mxCell>

        <!-- Graph API (top — closer to dispatcher) -->
        <mxCell id="graphapi" value="Microsoft Graph API&#xa;&#xa;Sites.Read.All&#xa;Files.Read.All" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="155" width="190" height="80" as="geometry" />
        </mxCell>

        <!-- SharePoint Online (bottom — worker streams from here) -->
        <mxCell id="sharepoint" value="SharePoint Online&#xa;&#xa;Document Libraries&#xa;(PDF, Office, text, images)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#217346;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="324" width="190" height="110" as="geometry" />
        </mxCell>

        <!-- Dispatcher (timer trigger) -->
        <mxCell id="dispatcher" value="Azure Function — Dispatcher&#xa;(Timer Trigger)&#xa;&#xa;1. Resolve processing mode&#xa;   (full / since-date / watermark)&#xa;2. List changed files via Graph&#xa;3. Enqueue one message per file&#xa;4. Advance watermark" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#FFFFFF;strokeColor=#005A9E;strokeWidth=3;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="130" width="260" height="180" as="geometry" />
        </mxCell>

        <!-- Queue -->
        <mxCell id="queue" value="Storage Queue&#xa;&#xa;sp-indexer-q&#xa;+ sp-indexer-q-poison&#xa;&#xa;(1 message per file)" style="shape=mxgraph.azure.queue;fillColor=#0078D4;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="160" width="100" height="100" as="geometry" />
        </mxCell>
        <mxCell id="queue_label" value="Storage Queue&#xa;sp-indexer-q&#xa;+ poison queue" style="text;html=1;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#0078D4;" vertex="1" parent="1">
          <mxGeometry x="650" y="260" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- Worker (queue trigger) -->
        <mxCell id="worker" value="Azure Function — Worker&#xa;(Queue Trigger, up to 40 instances)&#xa;&#xa;1. Stream download → /tmp&#xa;2. Path-based extractors&#xa;   (PDF, DOCX, XLSX, PPTX)&#xa;3. Image OCR via Doc Intelligence&#xa;4. Block-boundary chunking&#xa;5. Embed → push to AI Search&#xa;6. On failure → failedFiles table,&#xa;   5× dequeue → poison queue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#FFFFFF;strokeColor=#005A9E;strokeWidth=3;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="130" width="300" height="220" as="geometry" />
        </mxCell>

        <!-- Azure AI Vision multimodal (Florence, 1024d) — single embedder -->
        <mxCell id="openai" value="Azure AI Vision — Multimodal&#xa;Embeddings (Florence, 1024d)&#xa;&#xa;vectorizeText + vectorizeImage&#xa;share the same vector space.&#xa;&#xa;One hybrid query retrieves&#xa;both text and image chunks." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF8C00;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1270" y="130" width="200" height="140" as="geometry" />
        </mxCell>

        <!-- Document Intelligence (optional, Layout only) -->
        <mxCell id="docintel" value="Document Intelligence&#xa;(prebuilt-layout) — optional&#xa;&#xa;Reading-order paragraphs,&#xa;tables, figures with bounding&#xa;boxes for PDF/DOCX/PPTX/XLSX.&#xa;Not needed for standalone&#xa;image files." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#005A9E;fontColor=#FFFFFF;strokeColor=none;fontSize=10;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1270" y="290" width="200" height="140" as="geometry" />
        </mxCell>

        <!-- AI Search -->
        <mxCell id="aisearch" value="Azure AI Search&#xa;&#xa;sharepoint-index&#xa;(HNSW + Semantic Ranker)&#xa;&#xa;Single vector field:&#xa;content_embedding (1024d)&#xa;&#xa;Registered AI-Services-Vision&#xa;vectorizer — Copilot Studio&#xa;can query without client-side&#xa;embedding code." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0063B1;fontColor=#FFFFFF;strokeColor=none;fontSize=11;fontStyle=1;arcSize=10;verticalAlign=middle;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="995" y="413" width="250" height="200" as="geometry" />
        </mxCell>

