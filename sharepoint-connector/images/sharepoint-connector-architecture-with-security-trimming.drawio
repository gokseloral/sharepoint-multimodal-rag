        <mxCell id="e_user_copilot_lbl" value="Ask questions" style="edgeLabel;html=1;align=center;verticalAlign=bottom;fontSize=10;fontColor=#742774;fontStyle=1;" vertex="1" connectable="0" parent="e_user_copilot">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="-10" as="offset" /></mxGeometry>
        </mxCell>

        <!-- Auth / MI note -->
        <mxCell id="auth_note" value="All Azure service calls via&#xa;DefaultAzureCredential&#xa;(MI in prod, Azure CLI for dev)&#xa;&#xa;No API keys anywhere.&#xa;CLIENT_SECRET (if used) is&#xa;resolved from Key Vault via&#xa;@Microsoft.KeyVault reference." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;fontColor=#663300;strokeColor=#FF8C00;strokeWidth=1;dashed=1;fontSize=9;fontStyle=2;arcSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="450" width="220" height="160" as="geometry" />
